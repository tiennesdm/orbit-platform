      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(rate(orbit_http_requests_total[5m]))",
          "legendFormat": "Requests/sec",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Request rate (5m avg)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
