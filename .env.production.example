# =============================================================================
# ORBIT — Production environment variables (TEMPLATE)
# =============================================================================
# Copy to `.env.production`, fill in real values, NEVER commit that file.
#
# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# =============================================================================

NODE_ENV=production

# ----- JWT (REQUIRED) -----
JWT_SECRET=replace-with-48-byte-base64-secret
JWT_EXPIRES_IN=86400

# ----- API -----
API_PORT=4000
API_DOCS_PUBLIC=false
BODY_LIMIT=2mb
LOG_LEVEL=info
TRUST_PROXY=true
AUTO_MIGRATE=true
MIGRATION_FAIL_FAST=true

# ----- Database (REQUIRED) -----
VEDADB_ENGINE=postgres
VEDADB_HOST=postgres
VEDADB_PORT=5432
VEDADB_DATABASE=orbit
VEDADB_USER=orbit
VEDADB_PASSWORD=replace-with-strong-password
VEDADB_SSL=true
VEDADB_MAX_CONNECTIONS=20

# ----- Postgres (docker-compose) -----
POSTGRES_PASSWORD=replace-with-strong-password

# ----- CORS (REQUIRED, no wildcards) -----
CORS_ORIGINS=https://orbit.example.com,https://app.orbit.example.com

# ----- Public URL (for OAuth, emails, federation) -----
PUBLIC_DOMAIN=orbit.example.com
NEXT_PUBLIC_API_BASE=https://orbit.example.com/api/v1
NEXT_PUBLIC_WEB_BASE=https://orbit.example.com

# ----- WebAuthn (REQUIRED in production) -----
WEB_AUTHN_RP_NAME=ORBIT
WEB_AUTHN_RP_ID=orbit.example.com
WEB_AUTHN_ORIGIN=https://orbit.example.com

# ----- Sentry (optional but recommended) -----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----- AI (REQUIRED for real AI agent) -----
ANTHROPIC_API_KEY=replace-with-real-key

# ----- Federation -----
FEDERATION_ENABLED=true
PLC_DIRECTORY_URL=https://plc.directory

# ----- Email (SMTP for verification, notifications) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@orbit.example.com

# ----- Media (M-7: shared volume in K8s / docker-compose) -----
MEDIA_UPLOAD_DIR=/opt/orbit/uploads

# ----- Security contact (L-5: /.well-known/security.txt) -----
SECURITY_CONTACT_EMAIL=security@yourdomain.com
