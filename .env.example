# Vedadb configuration
VEDADB_HOST=localhost
VEDADB_PORT=5432
VEDADB_DATABASE=orbit
VEDADB_USER=orbit
VEDADB_PASSWORD=orbit_dev_password
VEDADB_SSL=false
VEDADB_REGION=us-east-1
VEDADB_SHARD_COUNT=1024

# Vedadb unified engine features
VEDADB_HOT_TIER_SIZE_MB=8192
VEDADB_ENABLE_FULLTEXT=true
VEDADB_ENABLE_VECTOR=true
VEDADB_ENABLE_PUBSUB=true
VEDADB_ENABLE_GEO=true
VEDADB_ANALYZER_LANGUAGES=en,hi,ta,bn,te,mr,gu

# For local dev: Postgres adapter (Vedadb-compatible mode)
# In production, switch to Vedadb connection string
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit_dev_password

# Cache & Pub/Sub (Vedadb in-memory tier in production)
# Local dev: use Vedadb's hot tier
VEDADB_CACHE_TTL_SECONDS=3600
VEDADB_PUBSUB_CHANNEL_PREFIX=orbit

# S3 / CDN (media binaries only — NOT in Vedadb)
S3_REGION=us-east-1
S3_BUCKET=orbit-media-dev
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_CDN_BASE=https://cdn.orbit-dev.com

# AI Agent
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
VEDADB_AI_RUNTIME=vllm
VEDADB_AI_MODEL=meta-llama/Llama-3.1-70B-Instruct
VEDADB_AI_ONDEVICE_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Auth
JWT_SECRET=change_me_in_production_at_least_32_chars
JWT_EXPIRES_IN=86400
WEBAUTHN_RP_NAME=Orbit
WEBAUTHN_RP_ID=localhost

# API
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3002,http://10.0.2.2:3002

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_VEDADB_URL=http://localhost:4000

# Observability
LOG_LEVEL=info
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Feature flags
ENABLE_E2E_ENCRYPTION=true
ENABLE_AI_AGENT=true
ENABLE_PORTABLE_IDENTITY=true
ENABLE_ANTI_ADDICTION=true
