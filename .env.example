# =============================================================================
# ORBIT Production .env.example
# Copy to .env and fill in real values. NEVER commit .env to git.
# Generate secrets: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info                          # trace|debug|info|warn|error|fatal
PORT=                                    # (not used; API_PORT below)
API_PORT=4000
PUBLIC_URL=https://orbit.example.com    # Used for CORS, OpenAPI docs, email links

# -----------------------------------------------------------------------------
# Secrets (REQUIRED — generate fresh for each env)
# -----------------------------------------------------------------------------
# JWT_SECRET: min 32 chars. Rotate every 90 days.
JWT_SECRET=                             # REQUIRED — generate with crypto.randomBytes(48).toString('base64')
JWT_EXPIRES_IN=86400                    # 24h access tokens
JWT_REFRESH_EXPIRES_IN=2592000          # 30d refresh tokens

# Cookie / session secret (for any signed cookies)
COOKIE_SECRET=                          # generate separately

# Encryption key for sensitive data at rest (32 bytes hex = 64 chars)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=                         # 64-char hex string

# -----------------------------------------------------------------------------
# Database (Vedadb / Postgres-compatible)
# -----------------------------------------------------------------------------
VEDADB_ENGINE=postgres                  # 'postgres' for local dev, 'vedadb' for real cluster
VEDADB_HOST=127.0.0.1
VEDADB_PORT=5432
VEDADB_DATABASE=orbit
VEDADB_USER=orbit
VEDADB_PASSWORD=                        # REQUIRED for prod (use secrets manager)
VEDADB_SSL=true                          # MUST be true in production
VEDADB_SSL_REJECT_UNAUTHORIZED=true      # Verify SSL cert (don't disable in prod)
VEDADB_MAX_CONNECTIONS=20                # Tune based on DB tier
VEDADB_STATEMENT_TIMEOUT_MS=30000        # 30s per query
VEDADB_REGION=us-east-1
VEDADB_SHARD_COUNT=1024

# Auto-run migrations on startup (recommended)
AUTO_MIGRATE=true
MIGRATION_FAIL_FAST=false               # false = log + continue (safe for prod)

# -----------------------------------------------------------------------------
# CORS
# Comma-separated allow-list. NEVER include "*" in production.
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://orbit.example.com,https://www.orbit.example.com

# Trust proxy (set true if behind nginx/cloudflare/load balancer)
TRUST_PROXY=true

# Body size limit
BODY_LIMIT=10mb

# -----------------------------------------------------------------------------
# AI Agent (optional — works without but returns echo fallback)
# -----------------------------------------------------------------------------
VEDADB_AI_RUNTIME=anthropic             # 'anthropic' | 'openai' | 'vllm'
VEDADB_AI_MODEL=claude-sonnet-4-5       # or llama-3.1-70b for self-hosted
ANTHROPIC_API_KEY=                      # Get from https://console.anthropic.com
OPENAI_API_KEY=                          # Alternative to Anthropic
AI_SERVER_URL=http://localhost:8000/v1  # For self-hosted vLLM

# -----------------------------------------------------------------------------
# Object storage (S3 / Vedadb blob / R2)
# -----------------------------------------------------------------------------
STORAGE_ADAPTER=s3                      # 's3' | 'local' | 'vedadb'
S3_REGION=us-east-1
S3_BUCKET=orbit-media-prod
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CDN_URL_BASE=https://cdn.orbit.example.com

# PDS (Personal Data Server) — per-user portable identity endpoints
PDS_BASE_URL=https://pds.orbit.example.com

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
THROTTLE_SHORT_LIMIT=10                 # Per second
THROTTLE_MEDIUM_LIMIT=100               # Per 10s
THROTTLE_LONG_LIMIT=1000                # Per minute

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Sentry (optional — copy DSN from sentry.io)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=            # For OpenTelemetry traces
OTEL_SERVICE_NAME=orbit-api

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
ENABLE_WEBHOOKS=true
API_DOCS_PUBLIC=false                   # Set true to expose /api/docs in prod
DEBUG_MODE=false

# =============================================================================
# Local dev only (not used in production)
# =============================================================================
# VEDADB_PORT=5434                          # Mac dev port (Postgres on 5434)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3002
# LOG_LEVEL=debug
# AUTO_MIGRATE=true
